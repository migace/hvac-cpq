# Application Settings
APP_NAME=cpq-hvac
APP_ENV=local
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000

# Database Configuration
# For local development use localhost, for Docker Compose use "db" as host
DATABASE_URL=postgresql+psycopg://cpq:cpq@localhost:5432/cpq_hvac

# Logging & Observability
LOG_LEVEL=INFO
OTEL_ENABLED=false

# CORS Settings (comma-separated origins)
CORS_ORIGINS=http://localhost:3000

# AI Agent (OpenAI) - Required for agent chat feature
# Get your API key from: https://platform.openai.com/account/api-keys
# ⚠️ NEVER commit this file with a real key! Use secrets management in production.
OPENAI_API_KEY=sk-xxx-your-actual-key-here
OPENAI_MODEL=gpt-4-mini